//- UserPageStats.js
// A non-Node server VALUE return (`PageStats`) cannot be refetched: it has no
// `id`, so `node(id:)` is meaningless, and it has no separate store record to
// refetch. Annotating the shadow field with @waterfall must therefore be a hard
// error: RelayResolversUnexpectedWaterfall.
/**
 * @relayField User.page_stats: PageStats
 * @rootFragment UserPageStatsResolverFragment
 * @returnFragment UserPageStatsReturnFragment
 */
graphql`fragment UserPageStatsResolverFragment on User {
  page {
    stats {
      ...UserPageStatsReturnFragment
    }
  }
}`

//- UserConsumer.js
graphql`query UserConsumerQuery {
  me {
    page_stats @waterfall {
      likeCount
    }
  }
}`

//- relay.config.json
{
