//- UserCombinedPage.js
// Consumer authors a CONCRETE server-typed fragment spread on a magic-fragment
// field. `combined_page` returns the client interface `IPage` (implemented by the
// SERVER type `Page`). The consumer spreads `...PageFields` where
// `fragment PageFields on Page`.
//
// The spread is INLINE-EXPANDED into the transplanted server selection
// in the MAIN operation (so `me { page { id __typename title } }` is fetched),
// while the reader keeps `...PageFields` as a masked `$fragmentSpreads` ref (the
// child `useFragment` reads its fields off the resolver-returned pointer).
/**
 * @relayField User.combined_page: IPage
 * @rootFragment UserCombinedPageResolverFragment
 * @returnFragment UserCombinedPageReturnFragment
 */
graphql`fragment UserCombinedPageResolverFragment on User {
  page {
    ...UserCombinedPageReturnFragment
  }
}`

//- PageFields.js
graphql`fragment PageFields on Page {
  title
}`

//- UserConsumer.js
graphql`query UserConsumerQuery {
  me {
    combined_page {
      ...PageFields @alias(as: "pageFields")
    }
  }
}`

