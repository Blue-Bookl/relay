//- QueryShadowThings.js
graphql`query QueryShadowThingsQuery($someIds: [ID!]!) {
  shadow_things(ids: $someIds) {
    id
    name
  }
}`

/**
 * @relayField Query.shadow_things: [IShadowThing]
 * @rootFragment QueryShadowThingsResolverFragment
 * @returnFragment QueryShadowThingsReturnFragment
 */
graphql`fragment QueryShadowThingsResolverFragment on Query
@argumentDefinitions(ids: {type: "[ID!]!"}) {
  nodes(ids: $ids) {
    ...QueryShadowThingsReturnFragment
  }
}`

//- ClientThingResolver.js
/**
 * @relayType ClientThing implements IShadowThing
 */
export function ClientThing() {}

//- ClientThingNameResolver.js
/**
 * @relayField ClientThing.name: String
 */
export function name() {}

//- relay.config.json
{
  "language": "flow",
  "jsModuleFormat": "haste",
  "schema": "schema.graphql",
  "schemaExtensions": ["schema-extensions"],
  "featureFlags": {
    "enable_shadow_resolvers": { "kind": "enabled" },
    "relay_resolver_enable_interface_output_type": { "kind": "enabled" }
  }
}

//- schema.graphql
interface Node {
  id: ID!
}

type User implements Node {
  id: ID!
  name: String
}

type Query {
  nodes(ids: [ID!]!): [Node]
}

//- schema-extensions/extension.graphql
interface IShadowThing implements Node {
  id: ID!
  name: String
}

extend type User implements IShadowThing
